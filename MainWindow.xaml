<Window x:Class="CyberWareASM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberWare With ASM — Cybersecurity Chatbot"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A1A"
        FontFamily="Segoe UI">

	<Window.Resources>

		<!-- ══════════════════════════════════════════
             GRADIENT BRUSHES
        ══════════════════════════════════════════ -->
		<LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#0F0C29" Offset="0"/>
			<GradientStop Color="#302B63" Offset="0.5"/>
			<GradientStop Color="#24243E" Offset="1"/>
		</LinearGradientBrush>

		<LinearGradientBrush x:Key="SendBtnGradient" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#3B82F6" Offset="0"/>
			<GradientStop Color="#A855F7" Offset="0.5"/>
			<GradientStop Color="#EC4899" Offset="1"/>
		</LinearGradientBrush>

		<LinearGradientBrush x:Key="EndBtnGradient" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#4B0082" Offset="0"/>
			<GradientStop Color="#EC4899" Offset="1"/>
		</LinearGradientBrush>

		<!-- Quiz button shares the same purple-pink palette -->
		<LinearGradientBrush x:Key="QuizBtnGradient" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#A855F7" Offset="0"/>
			<GradientStop Color="#EC4899" Offset="1"/>
		</LinearGradientBrush>

		<LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
			<GradientStop Color="#10102E" Offset="0"/>
			<GradientStop Color="#0D0D24" Offset="1"/>
		</LinearGradientBrush>

		<!-- ══════════════════════════════════════════
             SCROLLBAR STYLE
        ══════════════════════════════════════════ -->
		<Style x:Key="SlimScrollBar" TargetType="ScrollBar">
			<Setter Property="Width" Value="6"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ScrollBar">
						<Grid>
							<Track Name="PART_Track" IsDirectionReversed="True">
								<Track.Thumb>
									<Thumb>
										<Thumb.Template>
											<ControlTemplate TargetType="Thumb">
												<Border CornerRadius="3"
                                                        Background="#A855F7"
                                                        Opacity="0.55"/>
											</ControlTemplate>
										</Thumb.Template>
									</Thumb>
								</Track.Thumb>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ScrollViewer">
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<ScrollContentPresenter Grid.Column="0"/>
							<ScrollBar Grid.Column="1"
                                       Name="PART_VerticalScrollBar"
                                       Style="{StaticResource SlimScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             SEND BUTTON
        ══════════════════════════════════════════ -->
		<Style x:Key="SendButton" TargetType="Button">
			<Setter Property="Background"      Value="{StaticResource SendBtnGradient}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="22,0">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             QUIZ BUTTON  (same shape/size as Send)
        ══════════════════════════════════════════ -->
		<Style x:Key="QuizButton" TargetType="Button">
			<Setter Property="Background"      Value="{StaticResource QuizBtnGradient}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="18,0">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             END BUTTON
        ══════════════════════════════════════════ -->
		<Style x:Key="EndButton" TargetType="Button">
			<Setter Property="Background"      Value="{StaticResource EndBtnGradient}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="18,0">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             SUBMIT BUTTON  (name screen)
        ══════════════════════════════════════════ -->
		<Style x:Key="SubmitButton" TargetType="Button">
			<Setter Property="Background"      Value="{StaticResource SendBtnGradient}"/>
			<Setter Property="Foreground"      Value="White"/>
			<Setter Property="FontSize"        Value="15"/>
			<Setter Property="FontWeight"      Value="Bold"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Height"          Value="48"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="30,0">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             TOPIC / QUICK-ASK BUTTON  (sidebar)
        ══════════════════════════════════════════ -->
		<Style x:Key="TopicButton" TargetType="Button">
			<Setter Property="Background"      Value="#1E1B4B"/>
			<Setter Property="Foreground"      Value="#94A3B8"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="#2D2B5A"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Margin"          Value="0,3"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="12,8">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="10"/>
									<ColumnDefinition Width="*"/>
								</Grid.ColumnDefinitions>
								<Ellipse Grid.Column="0"
                                         Width="6" Height="6"
                                         Fill="#A855F7"
                                         VerticalAlignment="Center"/>
								<TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
							</Grid>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background"   Value="#2D2B5A"/>
								<Setter TargetName="Bd" Property="BorderBrush"  Value="#A855F7"/>
								<Setter Property="Foreground"                   Value="#F1F5F9"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Action buttons inside task / quiz panels -->
		<Style x:Key="ActionButton" TargetType="Button">
			<Setter Property="Background"      Value="#1E1B4B"/>
			<Setter Property="Foreground"      Value="#F1F5F9"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="FontWeight"      Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="#A855F7"/>
			<Setter Property="Cursor"          Value="Hand"/>
			<Setter Property="Padding"         Value="14,6"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="Bd" Property="Background" Value="#2D2B5A"/>
							</Trigger>
							<Trigger Property="IsPressed"   Value="True">
								<Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             CHAT INPUT BOX
        ══════════════════════════════════════════ -->
		<Style x:Key="ChatInput" TargetType="TextBox">
			<Setter Property="Background"               Value="#1C1C42"/>
			<Setter Property="Foreground"               Value="#F1F5F9"/>
			<Setter Property="CaretBrush"               Value="#A855F7"/>
			<Setter Property="FontSize"                 Value="14"/>
			<Setter Property="BorderThickness"          Value="1.5"/>
			<Setter Property="BorderBrush"              Value="#2D2B5A"/>
			<Setter Property="Padding"                  Value="16,0"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
							<ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0,16,0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter TargetName="Bd" Property="BorderBrush" Value="#A855F7"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- ══════════════════════════════════════════
             NAME SCREEN INPUT BOX
        ══════════════════════════════════════════ -->
		<Style x:Key="NameInput" TargetType="TextBox">
			<Setter Property="Background"      Value="#1C1C42"/>
			<Setter Property="Foreground"      Value="#F1F5F9"/>
			<Setter Property="CaretBrush"      Value="#A855F7"/>
			<Setter Property="FontSize"        Value="15"/>
			<Setter Property="BorderThickness" Value="1.5"/>
			<Setter Property="BorderBrush"     Value="#2D2B5A"/>
			<Setter Property="Padding"         Value="16,12"/>
			<Setter Property="Height"          Value="48"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
							<ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0,16,0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter TargetName="Bd" Property="BorderBrush" Value="#A855F7"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Shared panel input box (task fields) -->
		<Style x:Key="PanelInput" TargetType="TextBox">
			<Setter Property="Background"      Value="#1C1C42"/>
			<Setter Property="Foreground"      Value="#F1F5F9"/>
			<Setter Property="CaretBrush"      Value="#A855F7"/>
			<Setter Property="FontSize"        Value="13"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush"     Value="#2D2B5A"/>
			<Setter Property="Padding"         Value="10,8"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="TextBox">
						<Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
							<ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsFocused" Value="True">
								<Setter TargetName="Bd" Property="BorderBrush" Value="#A855F7"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

	</Window.Resources>

	<!-- ROOT GRID — Z-order layers -->
	<Grid>

		<!-- ══════════════════════════════════════════
             LAYER 1 ▸ NAME / WELCOME SCREEN
        ══════════════════════════════════════════ -->
		<Grid x:Name="NameScreen" Panel.ZIndex="10">
			<Grid.Background>
				<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
					<GradientStop Color="#0A0A1A" Offset="0"/>
					<GradientStop Color="#0F0C29" Offset="0.45"/>
					<GradientStop Color="#1A0A2E" Offset="1"/>
				</LinearGradientBrush>
			</Grid.Background>

			<Ellipse Width="500" Height="500" Opacity="0.05"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-160,-160,0,0">
				<Ellipse.Fill>
					<RadialGradientBrush>
						<GradientStop Color="#A855F7" Offset="0"/>
						<GradientStop Color="Transparent" Offset="1"/>
					</RadialGradientBrush>
				</Ellipse.Fill>
			</Ellipse>
			<Ellipse Width="420" Height="420" Opacity="0.05"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-110,-110">
				<Ellipse.Fill>
					<RadialGradientBrush>
						<GradientStop Color="#EC4899" Offset="0"/>
						<GradientStop Color="Transparent" Offset="1"/>
					</RadialGradientBrush>
				</Ellipse.Fill>
			</Ellipse>

			<Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="480" CornerRadius="24" Padding="48,44">
				<Border.Background>
					<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
						<GradientStop Color="#16163A" Offset="0"/>
						<GradientStop Color="#1E1B4B" Offset="1"/>
					</LinearGradientBrush>
				</Border.Background>
				<Border.Effect>
					<DropShadowEffect BlurRadius="60" ShadowDepth="0"
                                      Color="#A855F7" Opacity="0.28"/>
				</Border.Effect>

				<StackPanel>
					<StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,6">
						<Border Width="44" Height="44" CornerRadius="11" Margin="0,0,10,0">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
									<GradientStop Color="#3B82F6" Offset="0"/>
									<GradientStop Color="#A855F7" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<TextBlock Text="🔐" FontSize="21"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<TextBlock VerticalAlignment="Center" FontSize="22" FontWeight="Bold">
							<Run Text="Cyber"     Foreground="#3B82F6"/>
							<Run Text="Ware"      Foreground="#A855F7"/>
							<Run Text=" With ASM" Foreground="#EC4899"/>
						</TextBlock>
					</StackPanel>

					<TextBlock Text="CYBERSECURITY CHATBOT"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#475569"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

					<TextBlock Text="Welcome, Agent 👋"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#F1F5F9"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

					<TextBlock Text="Please identify yourself to begin&#xA;your secure session."
                               FontSize="14" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               LineHeight="22"
                               Margin="0,0,0,30"/>

					<TextBlock Text="First Name"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
					<TextBox x:Name="TxtFirstName"
                             Style="{StaticResource NameInput}"
                             Margin="0,0,0,16"/>

					<TextBlock Text="Last Name / Surname"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
					<TextBox x:Name="TxtSurname"
                             Style="{StaticResource NameInput}"
                             Margin="0,0,0,6"/>

					<TextBlock x:Name="TxtValidation"
                               Text="⚠  The textbox cannot be null, please enter Name and Surname."
                               FontSize="12" Foreground="#EC4899"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>

					<Button x:Name="BtnSubmitName"
                            Content="BEGIN SECURE SESSION  →"
                            Style="{StaticResource SubmitButton}"
                            Margin="0,10,0,0"
                            Click="BtnSubmitName_Click"/>
				</StackPanel>
			</Border>
		</Grid>

		<!-- ══════════════════════════════════════════
             LAYER 2 ▸ MAIN CHAT SCREEN
        ══════════════════════════════════════════ -->
		<Grid x:Name="ChatScreen" Visibility="Collapsed" Panel.ZIndex="5">
			<Grid.RowDefinitions>
				<RowDefinition Height="70"/>
				<!-- Header -->
				<RowDefinition Height="*"/>
				<!-- Content area -->
				<RowDefinition Height="76"/>
				<!-- Input bar -->
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="*"/>
				<!-- Chat + panels -->
				<ColumnDefinition Width="268"/>
				<!-- Sidebar -->
			</Grid.ColumnDefinitions>

			<!-- ── HEADER ── -->
			<Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource HeaderGradient}">
				<Border.Effect>
					<DropShadowEffect BlurRadius="18" ShadowDepth="2"
                                      Color="#000000" Opacity="0.55"/>
				</Border.Effect>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="20,0,0,0">
						<Border Width="38" Height="38" CornerRadius="10" Margin="0,0,12,0">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
									<GradientStop Color="#3B82F6" Offset="0"/>
									<GradientStop Color="#A855F7" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<TextBlock Text="🔐" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
						</Border>
						<StackPanel VerticalAlignment="Center">
							<TextBlock FontSize="17" FontWeight="Bold">
								<Run Text="Cyber"     Foreground="#3B82F6"/>
								<Run Text="Ware"      Foreground="#A855F7"/>
								<Run Text=" With ASM" Foreground="#EC4899"/>
							</TextBlock>
							<TextBlock Text="CYBERSECURITY CHATBOT"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#475569"/>
						</StackPanel>
					</StackPanel>

					<TextBlock x:Name="TxtHeaderStatus"
                               Grid.Column="1"
                               Text="[ SECURE SESSION ACTIVE ]"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="#2D2B5A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

					<StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,20,0">
						<Ellipse Width="8" Height="8" Fill="#22C55E"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
						<TextBlock Text="ONLINE"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#22C55E"
                                   VerticalAlignment="Center"/>
					</StackPanel>
				</Grid>
			</Border>

			<!-- ══════════════════════════════════════════
                 CONTENT AREA  — uses a Grid so chat, task
                 panel, and quiz panel can overlap / switch
            ══════════════════════════════════════════ -->
			<Grid Grid.Row="1" Grid.Column="0">

				<!-- ── CHAT AREA (default visible) ── -->
				<Border x:Name="ChatAreaBorder" Background="#0A0A1A">
					<ScrollViewer x:Name="ChatScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Style="{StaticResource ModernScrollViewer}"
                                  Padding="20,16,12,16">
						<StackPanel x:Name="ChatMessagesPanel" Orientation="Vertical"/>
					</ScrollViewer>
				</Border>

				<!-- ════════════════════════════════════
                     TASK ASSISTANT PANEL
                ════════════════════════════════════ -->
				<Border x:Name="TaskPanel" Visibility="Collapsed"
                        Background="#0A0A1A">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<!-- Header bar -->
							<RowDefinition Height="Auto"/>
							<!-- Form -->
							<RowDefinition Height="*"/>
							<!-- List -->
						</Grid.RowDefinitions>

						<!-- Panel header -->
						<Border Grid.Row="0" Padding="20,14" Margin="0,0,0,0">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
									<GradientStop Color="#16163A" Offset="0"/>
									<GradientStop Color="#1E1B4B" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0" Orientation="Horizontal">
									<TextBlock Text="📋" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
									<StackPanel VerticalAlignment="Center">
										<TextBlock Text="TASK ASSISTANT"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#F1F5F9"/>
										<TextBlock Text="Manage your cybersecurity tasks"
                                                   FontSize="11" Foreground="#94A3B8"/>
									</StackPanel>
								</StackPanel>
								<Button Grid.Column="1" Content="✕  Close"
                                        Style="{StaticResource ActionButton}"
                                        Click="BtnCloseTaskPanel_Click"/>
							</Grid>
						</Border>

						<!-- Add task form -->
						<Border Grid.Row="1" Padding="20,16" Margin="0,0,0,0"
                                BorderBrush="#1E1B4B" BorderThickness="0,1,0,1">
							<Border.Background>
								<SolidColorBrush Color="#0D0D24"/>
							</Border.Background>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<StackPanel Grid.Column="0" Margin="0,0,8,0">
									<TextBlock Text="TITLE" FontSize="10" FontWeight="Bold"
                                               Foreground="#A855F7" Margin="0,0,0,4"/>
									<TextBox x:Name="TxtTaskTitle"
                                             Style="{StaticResource PanelInput}"
                                             Height="36"/>
								</StackPanel>

								<StackPanel Grid.Column="1" Margin="0,0,8,0">
									<TextBlock Text="DESCRIPTION" FontSize="10" FontWeight="Bold"
                                               Foreground="#A855F7" Margin="0,0,0,4"/>
									<TextBox x:Name="TxtTaskDescription"
                                             Style="{StaticResource PanelInput}"
                                             Height="36"/>
								</StackPanel>

								<StackPanel Grid.Column="2" Margin="0,0,8,0">
									<TextBlock Text="REMINDER" FontSize="10" FontWeight="Bold"
                                               Foreground="#A855F7" Margin="0,0,0,4"/>
									<TextBox x:Name="TxtTaskReminder"
                                             Style="{StaticResource PanelInput}"
                                             Height="36"/>
								</StackPanel>

								<Button Grid.Column="3"
                                        Content="＋ Add Task"
                                        Style="{StaticResource ActionButton}"
                                        VerticalAlignment="Bottom"
                                        Height="36"
                                        Click="BtnAddTask_Click"/>
							</Grid>
						</Border>

						<!-- Task list -->
						<ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      Style="{StaticResource ModernScrollViewer}"
                                      Padding="20,12">
							<StackPanel>

								<TextBlock Text="YOUR TASKS" FontSize="10" FontWeight="Bold"
                                           Foreground="#3B82F6" Margin="0,0,0,10"/>

								<!-- ListView with task rows -->
								<ListView x:Name="TaskListView"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Foreground="#F1F5F9"
                                          SelectionMode="Single"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
									<ListView.ItemContainerStyle>
										<Style TargetType="ListViewItem">
											<Setter Property="Background"     Value="Transparent"/>
											<Setter Property="BorderBrush"    Value="#1E1B4B"/>
											<Setter Property="BorderThickness" Value="0,0,0,1"/>
											<Setter Property="Padding"        Value="0,6"/>
											<Setter Property="Margin"         Value="0,2"/>
											<Setter Property="HorizontalContentAlignment" Value="Stretch"/>
											<Style.Triggers>
												<Trigger Property="IsSelected" Value="True">
													<Setter Property="Background" Value="#1E1B4B"/>
												</Trigger>
												<Trigger Property="IsMouseOver" Value="True">
													<Setter Property="Background" Value="#16163A"/>
												</Trigger>
											</Style.Triggers>
										</Style>
									</ListView.ItemContainerStyle>
									<ListView.View>
										<GridView>
											<GridViewColumn Header="✓" Width="30"
                                                            DisplayMemberBinding="{Binding IsCompleteDisplay}"/>
											<GridViewColumn Header="Title" Width="200"
                                                            DisplayMemberBinding="{Binding Title}"/>
											<GridViewColumn Header="Description" Width="300"
                                                            DisplayMemberBinding="{Binding Description}"/>
											<GridViewColumn Header="Reminder" Width="180"
                                                            DisplayMemberBinding="{Binding Reminder}"/>
											<GridViewColumn Header="Created" Width="130"
                                                            DisplayMemberBinding="{Binding CreatedAt}"/>
										</GridView>
									</ListView.View>
								</ListView>

								<!-- Action buttons row -->
								<StackPanel Orientation="Horizontal" Margin="0,12,0,0" HorizontalAlignment="Right">
									<Button Content="✔  Mark Complete"
                                            Style="{StaticResource ActionButton}"
                                            Margin="0,0,8,0"
                                            Click="BtnMarkComplete_Click"/>
									<Button Content="🗑  Delete Task"
                                            Style="{StaticResource ActionButton}"
                                            Click="BtnDeleteTask_Click"/>
								</StackPanel>

							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Border>

				<!-- ════════════════════════════════════
                     QUIZ PANEL
                ════════════════════════════════════ -->
				<Border x:Name="QuizPanel" Visibility="Collapsed"
                        Background="#0A0A1A">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<!-- Header -->
							<RowDefinition Height="*"/>
							<!-- Question area -->
							<RowDefinition Height="Auto"/>
							<!-- Controls -->
						</Grid.RowDefinitions>

						<!-- Quiz panel header -->
						<Border Grid.Row="0" Padding="20,14">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
									<GradientStop Color="#16163A" Offset="0"/>
									<GradientStop Color="#1E1B4B" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<StackPanel Grid.Column="0" Orientation="Horizontal">
									<TextBlock Text="🎮" FontSize="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
									<StackPanel VerticalAlignment="Center">
										<TextBlock Text="CYBERSECURITY QUIZ"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#F1F5F9"/>
										<TextBlock x:Name="TxtQuizProgress"
                                                   Text="Question 1 of 12  |  Score: 0"
                                                   FontSize="11" Foreground="#94A3B8"/>
									</StackPanel>
								</StackPanel>
								<Button Grid.Column="1" Content="✕  Close"
                                        Style="{StaticResource ActionButton}"
                                        Click="BtnCloseQuizPanel_Click"/>
							</Grid>
						</Border>

						<!-- Question + options area -->
						<ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Style="{StaticResource ModernScrollViewer}"
                                      Padding="40,24">
							<StackPanel>

								<!-- Question text -->
								<Border CornerRadius="12" Padding="20,16" Margin="0,0,0,24">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#16163A" Offset="0"/>
											<GradientStop Color="#1E1B4B" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Border.Effect>
										<DropShadowEffect BlurRadius="14" ShadowDepth="0"
                                                          Color="#A855F7" Opacity="0.18"/>
									</Border.Effect>
									<TextBlock x:Name="TxtQuizQuestion"
                                               Text="Press 'Start Quiz' to begin."
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="#F1F5F9"
                                               TextWrapping="Wrap"
                                               LineHeight="26"/>
								</Border>

								<!-- Answer options — RadioButtons (multiple choice) -->
								<StackPanel x:Name="OptionsPanel" Margin="0,0,0,20">
									<RadioButton x:Name="RbA" GroupName="QuizOptions"
                                                 Foreground="#F1F5F9" FontSize="14"
                                                 Margin="0,0,0,10" Cursor="Hand"/>
									<RadioButton x:Name="RbB" GroupName="QuizOptions"
                                                 Foreground="#F1F5F9" FontSize="14"
                                                 Margin="0,0,0,10" Cursor="Hand"/>
									<RadioButton x:Name="RbC" GroupName="QuizOptions"
                                                 Foreground="#F1F5F9" FontSize="14"
                                                 Margin="0,0,0,10" Cursor="Hand"/>
									<RadioButton x:Name="RbD" GroupName="QuizOptions"
                                                 Foreground="#F1F5F9" FontSize="14"
                                                 Margin="0,0,0,10" Cursor="Hand"/>
								</StackPanel>

								<!-- True / False options (hidden for multiple choice) -->
								<StackPanel x:Name="TrueFalsePanel" Visibility="Collapsed"
                                            Orientation="Horizontal" Margin="0,0,0,20">
									<RadioButton x:Name="RbTrue"  Content="True"
                                                 GroupName="QuizOptions"
                                                 Foreground="#F1F5F9" FontSize="14"
                                                 Margin="0,0,24,0" Cursor="Hand"/>
									<RadioButton x:Name="RbFalse" Content="False"
                                                 GroupName="QuizOptions"
                                                 Foreground="#F1F5F9" FontSize="14"
                                                 Cursor="Hand"/>
								</StackPanel>

								<!-- Feedback area (hidden until answer submitted) -->
								<Border x:Name="FeedbackBorder"
                                        Visibility="Collapsed"
                                        CornerRadius="10" Padding="16,12"
                                        Margin="0,0,0,16"
                                        Background="#1C1C42">
									<TextBlock x:Name="TxtQuizFeedback"
                                               FontSize="14" Foreground="#F1F5F9"
                                               TextWrapping="Wrap" LineHeight="22"/>
								</Border>

								<!-- Final results screen (hidden during quiz) -->
								<Border x:Name="ResultsBorder"
                                        Visibility="Collapsed"
                                        CornerRadius="14" Padding="28,22"
                                        Margin="0,0,0,16">
									<Border.Background>
										<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
											<GradientStop Color="#1E1B4B" Offset="0"/>
											<GradientStop Color="#2D1B69" Offset="1"/>
										</LinearGradientBrush>
									</Border.Background>
									<Border.Effect>
										<DropShadowEffect BlurRadius="20" ShadowDepth="0"
                                                          Color="#A855F7" Opacity="0.25"/>
									</Border.Effect>
									<StackPanel HorizontalAlignment="Center">
										<TextBlock Text="🏆 QUIZ COMPLETE!"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="#F1F5F9"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,12"/>
										<TextBlock x:Name="TxtFinalScore"
                                                   FontSize="18" Foreground="#A855F7"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,10"/>
										<TextBlock x:Name="TxtFinalMessage"
                                                   FontSize="14" Foreground="#94A3B8"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,20"/>
										<Button Content="🔄  Play Again"
                                                Style="{StaticResource ActionButton}"
                                                HorizontalAlignment="Center"
                                                Click="BtnPlayAgain_Click"/>
									</StackPanel>
								</Border>

							</StackPanel>
						</ScrollViewer>

						<!-- Submit / Next controls -->
						<Border Grid.Row="2" Padding="40,12"
                                BorderBrush="#1E1B4B" BorderThickness="0,1,0,0"
                                Background="#0D0D24">
							<StackPanel Orientation="Horizontal">
								<Button x:Name="BtnSubmitAnswer"
                                        Content="✔  Submit Answer"
                                        Style="{StaticResource ActionButton}"
                                        Margin="0,0,12,0"
                                        Click="BtnSubmitAnswer_Click"/>
								<Button x:Name="BtnNextQuestion"
                                        Content="Next →"
                                        Style="{StaticResource ActionButton}"
                                        Visibility="Collapsed"
                                        Click="BtnNextQuestion_Click"/>
							</StackPanel>
						</Border>
					</Grid>
				</Border>

			</Grid>
			<!-- end content area Grid -->

			<!-- ── SIDEBAR ── -->
			<Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                    Background="{StaticResource SidebarGradient}"
                    BorderBrush="#1E1B4B" BorderThickness="1,0,0,0">
				<ScrollViewer VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource ModernScrollViewer}">
					<StackPanel Margin="16,20,16,16">

						<!-- User info card -->
						<Border CornerRadius="14" Padding="14" Margin="0,0,0,20">
							<Border.Background>
								<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
									<GradientStop Color="#1E1B4B" Offset="0"/>
									<GradientStop Color="#2D1B69" Offset="1"/>
								</LinearGradientBrush>
							</Border.Background>
							<Border.Effect>
								<DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                                  Color="#A855F7" Opacity="0.22"/>
							</Border.Effect>
							<StackPanel>
								<StackPanel Orientation="Horizontal" Margin="0,0,0,10">
									<Border Width="40" Height="40" CornerRadius="20" Margin="0,0,10,0">
										<Border.Background>
											<LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
												<GradientStop Color="#3B82F6" Offset="0"/>
												<GradientStop Color="#EC4899" Offset="1"/>
											</LinearGradientBrush>
										</Border.Background>
										<TextBlock Text="👤" FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
									</Border>
									<StackPanel VerticalAlignment="Center">
										<TextBlock Text="USER INFO"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="#A855F7"/>
										<TextBlock x:Name="TxtSidebarName"
                                                   Text="—"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#F1F5F9"/>
									</StackPanel>
								</StackPanel>
								<Separator Background="#2D2B5A" Margin="0,0,0,10"/>
								<TextBlock Text="FAVOURITE TOPIC"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="#EC4899"
                                           Margin="0,0,0,4"/>
								<TextBlock x:Name="TxtSidebarTopic"
                                           Text="Not set yet"
                                           FontSize="12"
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

						<!-- Topic buttons -->
						<TextBlock Text="TOPIC" FontSize="10" FontWeight="Bold"
                                   Foreground="#3B82F6" Margin="0,0,0,10"/>

						<Button Content="Network Security"            Tag="network security"      Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Application Security"        Tag="application security"  Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Cloud Security"              Tag="cloud security"        Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Endpoint Security"           Tag="endpoint security"     Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Threat Intelligence"         Tag="threat intelligence"   Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Incident Response"           Tag="incident response"     Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Cyber Awareness"             Tag="cyber awareness"       Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Cryptography"                Tag="cryptography"          Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Governance &amp; Compliance" Tag="governance"            Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Phishing"                    Tag="phishing"              Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Passwords"                   Tag="password"              Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Malware"                     Tag="malware"               Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Privacy"                     Tag="privacy"               Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
						<Button Content="Scams"                       Tag="scam"                  Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>

						<Separator Background="#1E1B4B" Margin="0,14"/>

						<!-- Quick asks -->
						<TextBlock Text="QUICK ASKS" FontSize="10" FontWeight="Bold"
                                   Foreground="#3B82F6" Margin="0,0,0,10"/>
						<Button Content="What can you do?" Tag="what can you do" Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
						<Button Content="Tell me more"     Tag="tell me more"    Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
						<Button Content="How are you?"     Tag="how are you"     Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
						<Button Content="Show Activity Log" Tag="show activity log" Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
						<Button Content="Help"             Tag="help"            Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>

						<Separator Background="#1E1B4B" Margin="0,14"/>

						<!-- Panel launchers -->
						<TextBlock Text="PANELS" FontSize="10" FontWeight="Bold"
                                   Foreground="#3B82F6" Margin="0,0,0,10"/>
						<Button Content="📋 Task Assistant" Tag="tasks"
                                Style="{StaticResource TopicButton}" Click="BtnOpenTaskPanel_Click"/>
						<Button Content="🎮 Start Quiz" Tag="quiz"
                                Style="{StaticResource TopicButton}" Click="BtnOpenQuizPanel_Click"/>

					</StackPanel>
				</ScrollViewer>
			</Border>

			<!-- ── INPUT BAR ── -->
			<Border Grid.Row="2" Grid.Column="0"
                    BorderBrush="#1E1B4B" BorderThickness="0,1,0,0"
                    Padding="16,12">
				<Border.Background>
					<LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
						<GradientStop Color="#10102A" Offset="0"/>
						<GradientStop Color="#0A0A1A" Offset="1"/>
					</LinearGradientBrush>
				</Border.Background>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<!-- Text box -->
						<ColumnDefinition Width="110"/>
						<!-- Send -->
						<ColumnDefinition Width="110"/>
						<!-- Quiz -->
						<ColumnDefinition Width="110"/>
						<!-- End -->
					</Grid.ColumnDefinitions>

					<!-- Input box -->
					<TextBox x:Name="TxtUserInput"
                             Grid.Column="0"
                             Style="{StaticResource ChatInput}"
                             Height="48"
                             KeyDown="TxtUserInput_KeyDown"
                             Margin="0,0,10,0"/>

					<!-- Placeholder text -->
					<TextBlock Grid.Column="0"
                               Text="Ask me anything about cybersecurity…"
                               Foreground="#475569" FontSize="13"
                               IsHitTestVisible="False"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center">
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Visibility" Value="Collapsed"/>
								<Style.Triggers>
									<DataTrigger Binding="{Binding Text, ElementName=TxtUserInput}" Value="">
										<Setter Property="Visibility" Value="Visible"/>
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>

					<!-- Send button -->
					<Button x:Name="BtnSend"
                            Grid.Column="1"
                            Content="⟶  SEND"
                            Style="{StaticResource SendButton}"
                            Height="48"
                            Margin="0,0,8,0"
                            Click="BtnSend_Click"/>

					<!-- Quiz button — sits right next to Send -->
					<Button x:Name="BtnQuiz"
                            Grid.Column="2"
                            Content="🎮 QUIZ"
                            Style="{StaticResource QuizButton}"
                            Height="48"
                            Margin="0,0,8,0"
                            Click="BtnOpenQuizPanel_Click"/>

					<!-- End button -->
					<Button x:Name="BtnEndConvo"
                            Grid.Column="3"
                            Content="⏻  END"
                            Style="{StaticResource EndButton}"
                            Height="48"
                            Click="BtnEndConvo_Click"/>
				</Grid>
			</Border>

		</Grid>
		<!-- end ChatScreen -->

	</Grid>
</Window>
